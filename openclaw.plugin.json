{
  "id": "xapi-search",
  "name": "xapi.to Web Search",
  "description": "xapi.to Web Search Provider for OpenClaw",
  "version": "0.1.0",
  "providers": ["xapi-search"],
  "providerAuthEnvVars": {
    "XAPI_API_KEY": "xapi-search"
  },
  "providerAuthChoices": [
    {
      "provider": "xapi-search",
      "method": "api-key",
      "choiceId": "xapi-api-key",
      "choiceLabel": "xapi.to API Key",
      "groupId": "xapi",
      "optionKey": "xapiApiKey",
      "cliFlag": "--xapi-api-key"
    }
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "xapi.to API Key (also configurable via XAPI_API_KEY env var)"
      },
      "locale": {
        "type": "string",
        "description": "Search locale / country code (e.g. \"us\", \"cn\", \"jp\"). Defaults to \"us\"."
      },
      "language": {
        "type": "string",
        "description": "Search language code (e.g. \"en\", \"zh-cn\", \"ja\"). Defaults to \"en\"."
      }
    }
  }
}
