{
  "id": "xapi-search",
  "description": "Web search provider powered by xapi.to unified API",
  "skills": ["./skills"],
  "providerAuthEnvVars": {
    "xapi": ["XAPI_KEY"]
  },
  "uiHints": {
    "webSearch.apiKey": {
      "label": "xapi.to API Key",
      "help": "xapi.to API key for web search.",
      "sensitive": true,
      "placeholder": "sk-..."
    },
    "webSearch.locale": {
      "label": "Search Locale",
      "help": "Search locale / country code (e.g. \"us\", \"cn\", \"jp\"). Defaults to \"us\"."
    },
    "webSearch.language": {
      "label": "Search Language",
      "help": "Search language code (e.g. \"en\", \"zh-cn\", \"ja\"). Defaults to \"en\"."
    }
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "webSearch": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": ["string", "object"]
          },
          "locale": {
            "type": "string"
          },
          "language": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
