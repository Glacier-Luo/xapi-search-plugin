{
  "name": "@xapi/openclaw-xapi-search",
  "version": "0.1.0",
  "description": "xapi.to Web Search Provider for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "src/index.ts",
    "src/types.ts",
    "src/lib/xapi-client.ts",
    "src/providers/web-search.ts",
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "xapi",
    "web-search"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=2026.3.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
