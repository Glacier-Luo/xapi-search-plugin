{
  "name": "@xapi/xapi-search",
  "version": "0.1.0",
  "description": "xapi.to Web Search Provider for OpenClaw",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "src/index.ts",
    "src/types.ts",
    "src/lib/xapi-client.ts",
    "src/providers/xapi-web-search-provider.ts",
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "xapi",
    "web-search"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=2026.3.7"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
